---
layout: base
---

<div>
  <sidebar :@page="page" :@main-menu="collections.mainMenu"></sidebar>

  <main id="main">
    <article>
      <page-hero
        :@image="heroImage"
        :@title="title"
        :@bgcolor="bgColor"
      ></page-hero>

      <template webc:if="sections" webc:nokeep>
        <page-sections :@sections="sections"></page-sections>
      </template>

      <template @raw="content" webc:nokeep></template>
    </article>
  </main>
</div>
