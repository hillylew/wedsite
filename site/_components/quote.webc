<section class="~py-6/12 first-of-type:~pt-12/24"" :class="bgcolor">
  <div class="container">
    <blockquote class="max-w-sm relative py-2 px-4">
      <span class="absolute top-0 left-0 font-cursive ~text-4xl/7xl">"</span>
      <span class="~text-2xl/5xl" @text="quote"></span>
      <span class="font-cursive ~text-4xl/7xl">"</span>
    </blockquote>

    <p class="~text-2xl/4xl font-cursive pl-6" webc:if="section.attribution" @text="section.attribution"></p>
  </div>
</section>
